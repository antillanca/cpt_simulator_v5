    "electricity_ohm_law": {
      "level": 14,
      "subject": "electricity",
      "status": "confirmed",
      "description": "Apply Ohm's law V=I*R. Given voltage=12 and resistance=4, compute current I=V/R and store in particle.x. Then compute power P=V*I and store in particle.y.",
      "lua_code": "local particle = {\n    x = 0,\n    y = 0,\n    vx = 0,\n    vy = 0\n}\n\nlocal voltage = 12\nlocal resistance = 4\n\n-- Compute current I = V/R\nlocal I = voltage / resistance\n\n-- Store current in particle.x\nparticle.x = I\n\n-- Compute power P = V*I\nlocal P = voltage * I\n\n-- Store power in particle.y\nparticle.y = P",
