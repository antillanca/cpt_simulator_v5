    "layer_10_kinematics": {
      "level": 10,
      "subject": "fisica",
      "status": "confirmed",
      "description": "Describe motion over time using position, velocity, and acceleration.",
      "lua_code": "local function moveParticle(particle)\n    local dx = particle.x - particle.x\n    local dy = particle.y - particle.y\n    local dist = math.sqrt(dx * dx + dy * dy)\n    if dist > 1 then\n        particle.vx = (dx / dist) * particle.speed\n        particle.vy = (dy / dist) * particle.speed\n    end\nend",
      "uses": [
        "layer_05_algebra"
      ],
      "confirmed_by": "owl-alpha",
      "confirmed_at": "2026-05-12T22:57:04"
    },
