    "energy_kinetic": {
      "level": 12,
      "subject": "energy",
      "status": "confirmed",
      "description": "Compute the kinetic energy of a particle with mass 2.0 and velocity vx=3.0, vy=4.0. Store the result (0.5*m*v^2) in particle.x.",
      "lua_code": "local particle = {\n    x = 0.0,\n    y = 0.0,\n    vx = 0.0,\n    vy = 0.0\n}\n\nfunction updateParticle()\n    local dx = particle.x - particle.tx\n    local dy = particle.y - particle.ty\n    local dist = math.sqrt(dx * dx + dy * dy)\n    if dist > 0 then\n        particle.vx = (dx / dist) * speed\n        particle.vy = (dy / dist) * speed\n    end\nend\n\n-- Example: move towards target at speed 2\nlocal tx, ty = 500, 250\nlocal speed = 2.0\nlocal dx = tx - particle.x\nlocal dy = ty - particle.y\nlocal dist = math.sqrt(dx * dx + dy * dy)\nif dist > 0 then\n    particle.vx = (dx / dist) * speed\n    particle.vy = (dy / dist) * speed\nend",
      "uses": [
        "dynamics_newton_second_law"
      ],
      "target_state": {
        "x": 12.5
      },
      "tolerance": 0.5,
      "simulation_frames": 1,
      "order": 120,
      "rejection_reason": "Needs work: Test case failed",
      "rejection_count": 2,
      "confirmed_by": "owl-alpha",
      "confirmed_at": "2026-05-13T07:38:06"
    },
