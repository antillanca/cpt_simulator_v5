    "waves_frequency_amplitude": {
      "level": 13,
      "subject": "waves",
      "status": "confirmed",
      "description": "Control wave parameters. Set particle.y = amplitude * sin(2 * pi * frequency * t) with amplitude=30 and frequency=0.1. After 10 frames, particle.y should be near 0.",
      "lua_code": "local particle = {\n    x = 0,\n    y = 0,\n    vx = 0,\n    vy = 0\n}\n\nfunction update()\n    particle.y = 30 * math.sin(2 * math.pi * 0.1 * (particle.t / 10))\nend\n\nfunction moveRight()\n    particle.vx = 2.0\nend\n\nfunction moveTowardsTarget()\n    local tx, ty = 500, 250\n    local speed = 2.0\n    local dx = tx - particle.x\n    local dy = ty - particle.y\n    local dist = math.sqrt(dx * dx + dy * dy)\n    if dist > 0 then\n        particle.vx = (dx / dist) * speed\n        particle.vy = (dy / dist) * speed\n    end\nend",
