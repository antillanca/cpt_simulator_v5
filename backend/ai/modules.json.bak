    "electromagnetism_maxwell": {
      "level": 25,
      "subject": "electromagnetism",
      "status": "confirmed",
      "description": "Simulate an electromagnetic wave: E-field oscillates as E=sin(x - c*t) where c=1. After 5 frames compute E at x=0 and store in particle.y.",
      "lua_code": "local particle = {\n    x = 0,\n    y = 0,\n    vx = 0,\n    vy = 0\n}\n\nfunction update()\n    local x, y = particle.x, particle.y\n    local dx = 0 - x\n    local dy = 0 - y\n    local dist = math.sqrt(dx*dx + dy*dy)\n    if dist > 0 then\n        particle.vx = (dx / dist) * 1\n        particle.vy = (dy / dist) * 1\n    end\nend\n\nfunction moveRight(speed)\n    particle.vx = speed\nend\n\nfunction moveTowardsTarget(target, speed)\n    local tx, ty = target.x, target.y\n    local dx = tx - particle.x\n    local dy = ty - particle.y\n    local dist = math.sqrt(dx*dx + dy*dy)\n    if dist > 0 then\n        particle.vx = (dx / dist) * speed\n        particle.vy = (dy / dist) * speed\n    end\nend\n\nupdate()",
      "uses": [
        "hamiltonian_mechanics"
      ],
      "target_state": {
        "y": -0.959
      },
