    "calculus_integral": {
      "level": 19,
      "subject": "calculus",
      "status": "confirmed",
      "description": "Compute the numerical integral (accumulation) of velocity. Given vx=2.0 constant over 10 frames, integrate to get total displacement and store in particle.x.",
      "lua_code": "-- Initialize particle table\nlocal particle = {\n    x = 0,\n    y = 0,\n    vx = 2.0,\n    vy = 0\n}\n\n-- Set velocity components\nfunction moveParticle(particle)\n    local dx = particle.x - particle.tx\n    local dy = particle.y - particle.ty\n    local dist = math.sqrt(dx*dx + dy*dy)\n    if dist > 1 then\n        particle.vx = (dx / dist) * particle.speed\n        particle.vy = (dy / dist) * particle.speed\n    end\nend\n\n-- Example: Move towards target at speed 2\nlocal tx, ty = 500, 250\nlocal speed = 2.0\nlocal dx = tx - particle.x\nlocal dy = ty - particle.y\nlocal dist = math.sqrt(dx*dx + dy*dy)\nif dist > 1 then\n    particle.vx = (dx / dist) * speed\n    particle.vy = (dy / dist) * speed\nend",
      "uses": [
        "calculus_derivative"
      ],
