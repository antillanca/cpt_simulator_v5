        "x": 20.0
      },
      "tolerance": 1.0,
      "simulation_frames": 10,
      "order": 190,
      "confirmed_by": "owl-alpha",
      "confirmed_at": "2026-05-13T07:40:57"
    },
    "differential_equations": {
      "level": 20,
      "subject": "differential",
      "status": "confirmed",
      "description": "Solve a simple ODE: dx/dt = -0.5 * x. Starting at x=100, evolve the system for 10 frames using Euler method. Store final value in particle.x.",
      "lua_code": "function differential_equations(args)\n    local particle = {\n        x = 100,\n        y = 0,\n        vx = 2.0,\n        vy = 0\n    }\n    \n    for _ in do\n        local dx = particle.x - particle.tx\n        local dy = particle.y - particle.ty\n        local dist = math.sqrt(dx*dx + dy*dy)\n        if dist > 1 then\n            particle.vx = (dx / dist) * args.speed\n            particle.vy = (dy / dist) * args.speed\n        end\n        particle.x = particle.x + particle.vx\n        particle.y = particle.y + particle.vy\n    end\n    \n    return particle.x\nend",
      "uses": [
        "calculus_integral"
      ],
      "target_state": {
        "x": 0.59
      },
      "tolerance": 0.5,
      "simulation_frames": 10,
      "order": 200,
      "confirmed_by": "owl-alpha",
      "confirmed_at": "2026-05-13T07:41:10"
    },
