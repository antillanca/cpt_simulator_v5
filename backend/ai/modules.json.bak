    "advanced_modeling": {
      "level": 17,
      "subject": "advanced",
      "status": "confirmed",
      "description": "Model a damped harmonic oscillator. Apply a restoring force proportional to -particle.x and a damping force proportional to -particle.vx. After 60 frames, particle.x should approach 0.",
      "lua_code": "local particle = {\n    x = 0,\n    y = 0,\n    vx = 0,\n    vy = 0\n}\n\nfunction update()\n    local dx = particle.x - particle.x\n    local dy = particle.y - particle.y\n    local dist = math.sqrt(dx * dx + dy * dy)\n    if dist > 1 then\n        particle.vx = (dx / dist) * 0.5\n        particle.vy = (dy / dist) * 0.5\n    end\nend\n\nfunction move()\n    particle.vx = 2.0\nend\n\nfunction update_frame()\n    update()\nend\n\nfunction run()\n    for i = 1, 60 do\n        update_frame()\n    end\nend",
      "uses": [
        "probability_statistics"
      ],
      "target_state": {
