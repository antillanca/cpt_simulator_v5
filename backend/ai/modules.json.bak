    "calculus_derivative": {
      "level": 18,
      "subject": "calculus",
      "status": "confirmed",
      "description": "Compute the numerical derivative of position with respect to time. Given that particle.x changes by 3.0 each frame, compute dx/dt and store in particle.vx.",
      "lua_code": "function calculus_derivative(args)\n    local dx = args.x - args.x\n    local dy = args.y - args.y\n    local dist = math.sqrt(dx * dx + dy * dy)\n    local result = (dx / dist) * 0.5\n    local result_vy = (dy / dist) * 0.5\n    return result\nend",
